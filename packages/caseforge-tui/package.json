    "test": "node --test test/*.test.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@verdict/caseforge-sdk": "*",
    "ink": "^6.8.0",
    "react": "^19.2.7"
  },
  "main": "./dist/src/index.js",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "ink-testing-library": "^4.0.0"
  }
}
