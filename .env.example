# caseforge-core environment (copy to .env; never commit real secrets)

# VERDICT toolkit checkout that provides the forensic MCP servers
VERDICT_DFIR_HOME=$HOME/verdict-dfir-community

# Privacy mode: local-only (default) | redacted-cloud | cloud-ok
CASEFORGE_PRIVACY=local-only

# Local OpenAI-compatible endpoint (Ollama default; vLLM = http://localhost:8000/v1)
VERDICT_LLM_BASEURL=http://localhost:11434/v1
VERDICT_LLM_APIKEY=local

# Cloud provider keys (only used in redacted-cloud / cloud-ok; leave unset for local-only)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
ZAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
# xAI Grok cloud (route: xai-grok / xai-grok-mini) — NOT local Ollama/Spark
XAI_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
